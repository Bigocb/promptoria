import { GET as syncHandler } from '@/app/api/sync/route'
import { NextRequest } from 'next/server'

// lib/prisma is mocked globally in jest.setup.js

jest.mock('@/lib/jwt', () => ({
  verifyAccessToken: jest.fn(),
}))

describe('GET /api/sync', () => {
  beforeEach(() => {
    jest.clearAllMocks()
  })

  const mockWorkspace = {
    id: 'workspace123',
    userId: 'user123',
  }

  const mockChanges = [
    {
      id: 'change1',
      action: 'create',
      entityType: 'prompt',
      entityId: 'prompt123',
      changedAt: new Date('2026-04-18T10:00:00Z'),
      data: { name: 'New Prompt', content: '...' },
    },
    {
      id: 'change2',
      action: 'update',
      entityType: 'snippet',
      entityId: 'snippet456',
      changedAt: new Date('2026-04-18T11:00:00Z'),
      data: { name: 'Updated Snippet' },
    },
  ]

  describe('Authentication', () => {
    test('returns 401 if Authorization header missing', async () => {
      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z')
      const response = await syncHandler(request)
      expect(response.status).toBe(401)

      const data = await response.json()
      expect(data.error).toBeDefined()
    })

    test('returns 401 if Bearer token invalid', async () => {
      const { verifyAccessToken } = require('@/lib/jwt')
      verifyAccessToken.mockImplementationOnce(() => {
        throw new Error('Invalid token')
      })

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer invalid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(401)

      const data = await response.json()
      expect(data.error).toBeDefined()
    })

    test('returns 401 if Bearer prefix missing', async () => {
      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'invalid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(401)

      const data = await response.json()
      expect(data.error).toBeDefined()
    })

    test('returns 401 if Authorization header is empty', async () => {
      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: '' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(401)
    })

    test('returns 401 if Bearer token verification fails', async () => {
      const { verifyAccessToken } = require('@/lib/jwt')
      verifyAccessToken.mockImplementationOnce(() => {
        throw new Error('Token expired')
      })

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer expired_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(401)
    })
  })

  describe('Parameter Validation', () => {
    beforeEach(() => {
      const { verifyAccessToken } = require('@/lib/jwt')
      verifyAccessToken.mockReturnValue({ userId: 'user123', email: 'test@example.com' })
    })

    test('returns 400 if lastSync parameter missing', async () => {
      const request = new NextRequest('http://localhost:3000/api/sync', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(400)

      const data = await response.json()
      expect(data.error).toBeDefined()
    })

    test('returns 400 if lastSync timestamp invalid format', async () => {
      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=not-a-timestamp', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(400)

      const data = await response.json()
      expect(data.error).toBeDefined()
    })

    test('returns 400 if lastSync is empty string', async () => {
      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(400)
    })

    test('returns 400 if lastSync has invalid format (YYYY-MM-DD only)', async () => {
      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(400)
    })

    test('accepts valid ISO 8601 timestamp format', async () => {
      const { verifyAccessToken } = require('@/lib/jwt')verifyAccessToken.mockReturnValue({ userId: 'user123', email: 'test@example.com' })
      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce([])

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(200)
    })
  })

  describe('Workspace Validation', () => {
    beforeEach(() => {
      const { verifyAccessToken } = require('@/lib/jwt')
      verifyAccessToken.mockReturnValue({ userId: 'user123', email: 'test@example.com' })
    })

    test('returns 404 if user workspace not found', async () => {PrismaClient.mockImplementationOnce(() => ({
        workspace: {
          findFirst: jest.fn().mockResolvedValueOnce(null),
        },
        syncLog: {
          findMany: jest.fn(),
        },
      }))

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(404)

      const data = await response.json()
      expect(data.error).toBeDefined()
    })

    test('queries workspace with correct userId', async () => {
      const { PrismaClient } = require('@/lib/jwt')
      const { verifyAccessToken } = require('@/lib/jwt')

      verifyAccessToken.mockReturnValue({ userId: 'user123', email: 'test@example.com' })
      const mockFindFirst = jest.fn().mockResolvedValueOnce(mockWorkspace)

      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst = mockFindFirst
      prisma.syncLog.findMany.mockResolvedValueOnce([])

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      await syncHandler(request)

      expect(mockFindFirst).toHaveBeenCalledWith(
        expect.objectContaining({
          where: expect.objectContaining({
            userId: 'user123',
          }),
        })
      )
    })
  })

  describe('Successful Sync Response', () => {
    beforeEach(() => {
      const { verifyAccessToken } = require('@/lib/jwt')
      verifyAccessToken.mockReturnValue({ userId: 'user123', email: 'test@example.com' })
    })

    test('returns 200 with changes array on success', async () => {
      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce(mockChanges)

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(response.status).toBe(200)
      expect(data.synced_at).toBeDefined()
      expect(data.changes).toEqual(expect.any(Array))
      expect(data.conflicts).toEqual(expect.any(Array))
    })

    test('returns correct response structure', async () => {
      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce(mockChanges)

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(data).toHaveProperty('synced_at')
      expect(data).toHaveProperty('changes')
      expect(data).toHaveProperty('conflicts')
      expect(typeof data.synced_at).toBe('string')
      expect(Array.isArray(data.changes)).toBe(true)
      expect(Array.isArray(data.conflicts)).toBe(true)
    })

    test('returns changes with correct count', async () => {
      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce(mockChanges)

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(data.changes).toHaveLength(2)
    })

    test('returns empty changes array if no changes since lastSync', async () => {
      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce([])

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(response.status).toBe(200)
      expect(data.changes).toEqual([])
    })

    test('returns synced_at timestamp as ISO string', async () => {
      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce(mockChanges)

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(typeof data.synced_at).toBe('string')
      expect(() => new Date(data.synced_at)).not.toThrow()
    })

    test('includes all change fields (action, entityType, entityId, data)', async () => {
      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce(mockChanges)

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      const change = data.changes[0]
      expect(change).toHaveProperty('action')
      expect(change).toHaveProperty('entityType')
      expect(change).toHaveProperty('entityId')
      expect(change).toHaveProperty('data')
      expect(change.action).toBe('create')
      expect(change.entityType).toBe('prompt')
      expect(change.entityId).toBe('prompt123')
      expect(change.data).toBeDefined()
    })

    test('returns conflicts array (empty by default)', async () => {
      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce(mockChanges)

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(data.conflicts).toEqual([])
    })
  })

  describe('Query Filtering and Pagination', () => {
    beforeEach(() => {
      const { verifyAccessToken } = require('@/lib/jwt')
      verifyAccessToken.mockReturnValue({ userId: 'user123', email: 'test@example.com' })
    })

    test('filters changes to user workspace only', async () => {const mockFindMany = jest.fn().mockResolvedValueOnce([])
      PrismaClient.mockImplementationOnce(() => ({
        workspace: {
          findFirst: jest.fn().mockResolvedValueOnce(mockWorkspace),
        },
        syncLog: {
          findMany: mockFindMany,
        },
      }))

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      await syncHandler(request)

      expect(mockFindMany).toHaveBeenCalledWith(
        expect.objectContaining({
          where: expect.objectContaining({
            workspaceId: mockWorkspace.id,
          }),
        })
      )
    })

    test('filters changes by lastSync timestamp', async () => {const mockFindMany = jest.fn().mockResolvedValueOnce([])
      PrismaClient.mockImplementationOnce(() => ({
        workspace: {
          findFirst: jest.fn().mockResolvedValueOnce(mockWorkspace),
        },
        syncLog: {
          findMany: mockFindMany,
        },
      }))

      const lastSyncTime = '2026-04-18T00:00:00Z'
      const request = new NextRequest(`http://localhost:3000/api/sync?lastSync=${lastSyncTime}`, {
        headers: { Authorization: 'Bearer valid_token' },
      })
      await syncHandler(request)

      expect(mockFindMany).toHaveBeenCalledWith(
        expect.objectContaining({
          where: expect.objectContaining({
            changedAt: expect.objectContaining({
              gt: expect.any(Date),
            }),
          }),
        })
      )
    })

    test('limits changes to 100 per request', async () => {const mockFindMany = jest.fn().mockResolvedValueOnce([])
      PrismaClient.mockImplementationOnce(() => ({
        workspace: {
          findFirst: jest.fn().mockResolvedValueOnce(mockWorkspace),
        },
        syncLog: {
          findMany: mockFindMany,
        },
      }))

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      await syncHandler(request)

      expect(mockFindMany).toHaveBeenCalledWith(
        expect.objectContaining({ take: 100 })
      )
    })

    test('orders changes by changedAt ascending', async () => {const mockFindMany = jest.fn().mockResolvedValueOnce([])
      PrismaClient.mockImplementationOnce(() => ({
        workspace: {
          findFirst: jest.fn().mockResolvedValueOnce(mockWorkspace),
        },
        syncLog: {
          findMany: mockFindMany,
        },
      }))

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      await syncHandler(request)

      expect(mockFindMany).toHaveBeenCalledWith(
        expect.objectContaining({
          orderBy: expect.objectContaining({
            changedAt: 'asc',
          }),
        })
      )
    })

    test('returns changes ordered by changedAt ascending in response', async () => {const orderedChanges = [
        {
          id: 'change1',
          action: 'create',
          entityType: 'prompt',
          entityId: 'prompt123',
          changedAt: new Date('2026-04-18T10:00:00Z'),
          data: { name: 'First' },
        },
        {
          id: 'change2',
          action: 'update',
          entityType: 'snippet',
          entityId: 'snippet456',
          changedAt: new Date('2026-04-18T11:00:00Z'),
          data: { name: 'Second' },
        },
        {
          id: 'change3',
          action: 'delete',
          entityType: 'prompt',
          entityId: 'prompt789',
          changedAt: new Date('2026-04-18T12:00:00Z'),
          data: null,
        },
      ]

      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce(orderedChanges)

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      for (let i = 0; i < data.changes.length - 1; i++) {
        const current = new Date(data.changes[i].changedAt)
        const next = new Date(data.changes[i + 1].changedAt)
        expect(current.getTime()).toBeLessThanOrEqual(next.getTime())
      }
    })
  })

  describe('Change Data Types', () => {
    beforeEach(() => {
      const { verifyAccessToken } = require('@/lib/jwt')
      verifyAccessToken.mockReturnValue({ userId: 'user123', email: 'test@example.com' })
    })

    test('handles create action changes', async () => {const createChange = {
        id: 'change1',
        action: 'create',
        entityType: 'prompt',
        entityId: 'prompt123',
        changedAt: new Date('2026-04-18T10:00:00Z'),
        data: { name: 'New Prompt', content: 'test content' },
      }

      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce([createChange])

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(data.changes[0].action).toBe('create')
      expect(data.changes[0].data).toBeDefined()
    })

    test('handles update action changes', async () => {const updateChange = {
        id: 'change1',
        action: 'update',
        entityType: 'snippet',
        entityId: 'snippet456',
        changedAt: new Date('2026-04-18T10:00:00Z'),
        data: { name: 'Updated Snippet' },
      }

      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce([updateChange])

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(data.changes[0].action).toBe('update')
    })

    test('handles delete action changes', async () => {const deleteChange = {
        id: 'change1',
        action: 'delete',
        entityType: 'prompt',
        entityId: 'prompt789',
        changedAt: new Date('2026-04-18T10:00:00Z'),
        data: null,
      }

      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce([deleteChange])

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(data.changes[0].action).toBe('delete')
    })

    test('handles various entity types', async () => {const entityTypes = ['prompt', 'snippet', 'workspace', 'collection']
      const changes = entityTypes.map((type, i) => ({
        id: `change${i}`,
        action: 'create',
        entityType: type,
        entityId: `entity${i}`,
        changedAt: new Date('2026-04-18T10:00:00Z'),
        data: {},
      }))

      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce(changes)

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(data.changes).toHaveLength(4)
      entityTypes.forEach((type, i) => {
        expect(data.changes[i].entityType).toBe(type)
      })
    })
  })

  describe('Error Handling', () => {
    beforeEach(() => {
      const { verifyAccessToken } = require('@/lib/jwt')
      verifyAccessToken.mockReturnValue({ userId: 'user123', email: 'test@example.com' })
    })

    test('handles database connection errors gracefully', async () => {PrismaClient.mockImplementationOnce(() => ({
        workspace: {
          findFirst: jest.fn().mockRejectedValueOnce(new Error('Database connection failed')),
        },
        syncLog: {
          findMany: jest.fn(),
        },
      }))

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(500)
    })

    test('handles invalid lastSync with non-ISO format gracefully', async () => {
      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026/04/18', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(400)
    })

    test('returns error message in JSON format', async () => {
      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=invalid', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(data).toHaveProperty('error')
      expect(typeof data.error).toBe('string')
    })
  })

  describe('Edge Cases', () => {
    beforeEach(() => {
      const { verifyAccessToken } = require('@/lib/jwt')
      verifyAccessToken.mockReturnValue({ userId: 'user123', email: 'test@example.com' })
    })

    test('handles lastSync timestamp at epoch', async () => {
      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce([])

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=1970-01-01T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(200)
    })

    test('handles lastSync timestamp in future', async () => {
      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce([])

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2099-12-31T23:59:59Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(200)
      const data = await response.json()
      expect(data.changes).toEqual([])
    })

    test('handles response with exactly 100 changes (pagination boundary)', async () => {const hundredChanges = Array.from({ length: 100 }, (_, i) => ({
        id: `change${i}`,
        action: 'create',
        entityType: 'prompt',
        entityId: `prompt${i}`,
        changedAt: new Date(`2026-04-18T${String(i).padStart(2, '0')}:00:00Z`),
        data: { index: i },
      }))

      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce(hundredChanges)

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(data.changes).toHaveLength(100)
    })

    test('handles workspace with special characters in ID', async () => {const specialWorkspace = {
        id: 'workspace-123_abc_456',
        userId: 'user123',
      }

      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(specialWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce([])

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      expect(response.status).toBe(200)
    })

    test('handles change data with nested objects', async () => {const complexChange = {
        id: 'change1',
        action: 'create',
        entityType: 'prompt',
        entityId: 'prompt123',
        changedAt: new Date('2026-04-18T10:00:00Z'),
        data: {
          name: 'Complex Prompt',
          metadata: {
            tags: ['tag1', 'tag2'],
            settings: {
              temperature: 0.7,
              maxTokens: 1000,
            },
          },
        },
      }

      const prisma = require('@/lib/prisma').default
      prisma.workspace.findFirst.mockResolvedValueOnce(mockWorkspace)
      prisma.syncLog.findMany.mockResolvedValueOnce([complexChange])

      const request = new NextRequest('http://localhost:3000/api/sync?lastSync=2026-04-18T00:00:00Z', {
        headers: { Authorization: 'Bearer valid_token' },
      })
      const response = await syncHandler(request)
      const data = await response.json()

      expect(data.changes[0].data.metadata.settings.temperature).toBe(0.7)
    })
  })
})
