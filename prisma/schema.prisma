// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User - authentication
model User {
  id        String   @id @default(cuid()) @db.VarChar(36)
  email     String   @unique @db.VarChar(255)
  password  String?  @db.VarChar(255)
  name      String?  @db.VarChar(255)
  image     String?  @db.VarChar(500)
  created_at    DateTime      @default(now()) @db.Timestamp(6)
  updated_at    DateTime      @default(now()) @updatedAt @db.Timestamp(6)

  user_settings UserSettings?
  workspaces    Workspace?
  devices       Device[]
  oauth_accounts OAuthAccount[]
  favorites     Favorite[]

  @@map("users")
}

// Favorite - user's favorited prompts
model Favorite {
  id         String   @id @default(cuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  prompt_id  String   @db.VarChar(36)
  created_at DateTime @default(now()) @db.Timestamp(6)

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  prompt Prompt @relation(fields: [prompt_id], references: [id], onDelete: Cascade)

  @@unique([user_id, prompt_id])
  @@index([user_id])
  @@map("favorites")
}

// OAuthAccount - third-party auth providers
model OAuthAccount {
  id           String   @id @default(cuid()) @db.VarChar(36)
  provider     String   @db.VarChar(20)
  provider_id  String   @db.VarChar(255)
  user_id      String   @db.VarChar(36)
  access_token  String?  @db.Text
  refresh_token String?  @db.Text
  created_at   DateTime @default(now()) @db.Timestamp(6)
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamp(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_id])
  @@index([user_id])
  @@map("oauth_accounts")
}

// Device - track iOS/Android app instances
model Device {
  id            String   @id @default(cuid()) @db.VarChar(36)
  user_id       String   @db.VarChar(36)
  device_type   String   @db.VarChar(20)   // "ios" or "android"
  device_name   String   @db.VarChar(255)  // e.g., "iPhone 14 Pro", "Samsung Galaxy S23"
  app_version   String   @db.VarChar(20)   // e.g., "1.0.0"
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamp(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("devices")
}

// UserSettings - user preferences
model UserSettings {
  id                  String   @id @default(cuid()) @db.VarChar(36)
  user_id             String   @unique @db.VarChar(36)
  theme               String?  @db.VarChar(50)
  suggestions_enabled Boolean?
  default_model       String?  @db.VarChar(100)
  default_temperature Float?
  default_max_tokens  Int?
  anthropic_api_key   String?  @db.Text
  created_at          DateTime @default(now()) @db.Timestamp(6)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamp(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// Workspace
model Workspace {
  id        String   @id @default(cuid()) @db.VarChar(36)
  name      String   @db.VarChar(255)
  slug      String   @db.VarChar(255)
  user_id   String   @unique @db.VarChar(36)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(6)

  user                  User                    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  prompts               Prompt[]
  snippets              Snippet[]
  interaction_types     AgentInteractionType[]
  prompt_categories     PromptCategory[]
  test_runs             TestRun[]
  sync_logs             SyncLog[]

  @@map("workspaces")
}

// AgentInteractionType - top-level category
model AgentInteractionType {
  id            String   @id @default(cuid()) @db.VarChar(36)
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  emoji         String?  @db.VarChar(10)
  workspace_id  String   @db.VarChar(36)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamp(6)

  workspace   Workspace        @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  categories  PromptCategory[]

  @@unique([workspace_id, name])
  @@index([workspace_id])
  @@map("agent_interaction_types")
}

// PromptCategory - subcategory under interaction type
model PromptCategory {
  id                           String   @id @default(cuid()) @db.VarChar(36)
  name                         String   @db.VarChar(255)
  description                  String?  @db.Text
  workspace_id                 String   @db.VarChar(36)
  agent_interaction_type_id    String   @db.VarChar(36)
  created_at                   DateTime @default(now()) @db.Timestamp(6)
  updated_at                   DateTime @default(now()) @updatedAt @db.Timestamp(6)

  workspace         Workspace              @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  interaction_type  AgentInteractionType   @relation(fields: [agent_interaction_type_id], references: [id], onDelete: Cascade)
  prompts           Prompt[]

  @@unique([workspace_id, name])
  @@index([workspace_id])
  @@index([agent_interaction_type_id])
  @@map("prompt_categories")
}

// Prompt - prompt template
model Prompt {
  id            String   @id @default(cuid()) @db.VarChar(36)
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  workspace_id  String   @db.VarChar(36)
  category_id   String?  @db.VarChar(36)
  tags          Json?    @db.Json // Array of tags
  model         String   @default("llama3.2") @db.VarChar(100)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamp(6)

  workspace Workspace        @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  category  PromptCategory?  @relation(fields: [category_id], references: [id], onDelete: SetNull)
  versions  PromptVersion[]
  favorites  Favorite[]

  @@unique([workspace_id, name])
  @@index([workspace_id])
  @@index([category_id])
  @@map("prompts")
}

// PromptVersion - immutable snapshot of a prompt
model PromptVersion {
  id              String   @id @default(cuid()) @db.VarChar(36)
  version_number  Int
  prompt_id       String   @db.VarChar(36)
  template_body   String   @db.Text
  model_config    Json?    @db.Json // {temperature, maxTokens, topP, etc}
  change_log      String?  @db.Text
  created_by      String?  @db.VarChar(255)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamp(6)

  prompt        Prompt              @relation(fields: [prompt_id], references: [id], onDelete: Cascade)
  compositions  PromptComposition[]
  test_runs     TestRun[]

  @@unique([prompt_id, version_number])
  @@index([prompt_id])
  @@map("prompt_versions")
}

// Snippet - reusable text block
model Snippet {
  id            String   @id @default(cuid()) @db.VarChar(36)
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  content       String   @db.Text
  workspace_id  String   @db.VarChar(36)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamp(6)

  workspace    Workspace            @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  compositions PromptComposition[]

  @@unique([workspace_id, name])
  @@index([workspace_id])
  @@map("snippets")
}

// PromptComposition - join table linking snippets to prompt versions (ordered)
model PromptComposition {
  id                 String   @id @default(cuid()) @db.VarChar(36)
  prompt_version_id  String   @db.VarChar(36)
  snippet_id         String   @db.VarChar(36)
  rank               Int      @default(0) // Order of snippet in composition (0-indexed)
  created_at         DateTime @default(now()) @db.Timestamp(6)

  prompt_version PromptVersion @relation(fields: [prompt_version_id], references: [id], onDelete: Cascade)
  snippet        Snippet       @relation(fields: [snippet_id], references: [id], onDelete: Cascade)

  @@unique([prompt_version_id, snippet_id])
  @@index([prompt_version_id])
  @@index([snippet_id])
  @@map("prompt_compositions")
}

// TestRun - prompt evaluation/testing
model TestRun {
  id                String   @id @default(cuid()) @db.VarChar(36)
  workspace_id      String   @db.VarChar(36)
  prompt_version_id String   @db.VarChar(36)
  test_case_input   String   @db.Text
  output            String?  @db.Text
  status            String   @default("pending") @db.VarChar(20) // pending, running, success, error
  error_message     String?  @db.Text
  started_at        DateTime?
  completed_at      DateTime?
  duration_ms       Int?     // milliseconds
  created_at        DateTime @default(now()) @db.Timestamp(6)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamp(6)

  workspace       Workspace      @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  prompt_version  PromptVersion  @relation(fields: [prompt_version_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
  @@index([prompt_version_id])
  @@map("test_runs")
}

// SyncLog - change tracking for offline-first sync
model SyncLog {
  id            String   @id @default(cuid()) @db.VarChar(36)
  device_id     String?  @db.VarChar(36)
  workspace_id  String   @db.VarChar(36)
  action        String   @db.VarChar(20)   // "create", "update", "delete"
  entity_type   String   @db.VarChar(50)   // "prompt", "snippet", etc.
  entity_id     String   @db.VarChar(36)
  changed_at    DateTime @default(now()) @db.Timestamp(6)
  data          Json?    @db.Json          // Full or delta data
  created_at    DateTime @default(now()) @db.Timestamp(6)

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
  @@index([changed_at])
  @@map("sync_logs")
}
