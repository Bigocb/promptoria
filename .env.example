# Database
DATABASE_URL="postgresql://user:password@localhost:5432/promptarchitect"

# Authentication
JWT_SECRET="change-this-to-a-secure-secret"

# Ollama Cloud (or local Ollama)
# Set this to your Ollama Cloud URL or http://localhost:11434 for local
OLLAMA_BASE_URL="https://api.ollama.cloud"
OLLAMA_API_KEY="your-ollama-cloud-api-key"

# App Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Promptoria"
NEXT_PUBLIC_API_URL="https://promptoria.me/api"